install.packages("devtools")
# Install Packages
install.packages(c("devtools", "roxygen2"))
#' Report Missing Values in a Data Frame
#'
#' Counts NA values for each column and returns a summary.
#'
#' @param data A data frame
#' @return An object of class "na_report" with NA counts and percentages
#' @export
#' @examples
#' na_report(airquality)
na_report <- function(data) {
if (!is.data.frame(data)) {
stop("Input must be a data frame")
}
counts <- sapply(data, function(x) sum(is.na(x)))
pct <- round((counts / nrow(data)) * 100, 1)
out <- data.frame(
variable = names(data),
missing = counts,
percent = pct,
row.names = NULL
)
class(out) <- c("na_report", "data.frame")
return(out)
}
#' @export
print.na_report <- function(x, ...) {
cat("Missing Value Report\n")
cat("--------------------\n")
cat("Total rows:", attr(x, "n_rows"), "\n\n")
print.data.frame(x)
invisible(x)
}
#'
#' Removes rows from a data frame that contain any NA values.
#'
#' @param data A data frame
#' @return A data frame with NA rows removed
#' @export
#' @examples
#' clean <- drop_na_rows(airquality)
#' nrow(airquality)
#' nrow(clean)
drop_na_rows <- function(data) {
if (!is.data.frame(data)) {
stop("Input must be a data frame")
}
data[complete.cases(data), ]
}
#'
#' Replaces NA values in numeric columns using the column mean or median.
#'
#' @param data A data frame
#' @param method Either "mean" or "median"
#' @return A data frame with NAs filled in numeric columns
#' @export
#' @examples
#' filled <- fill_na(airquality, method = "mean")
#' sum(is.na(filled$Ozone))
fill_na <- function(data, method = "mean") {
if (!is.data.frame(data)) {
stop("Input must be a data frame")
}
if (!method %in% c("mean", "median")) {
stop("Method must be 'mean' or 'median'")
}
for (col in names(data)) {
if (is.numeric(data[[col]])) {
missing <- is.na(data[[col]])
if (any(missing)) {
if (method == "mean") {
data[[col]][missing] <- mean(data[[col]], na.rm = TRUE)
} else {
data[[col]][missing] <- median(data[[col]], na.rm = TRUE)
}
}
}
}
return(data)
}
